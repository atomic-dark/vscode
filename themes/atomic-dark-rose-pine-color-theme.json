    "tokenColors": [
        {
            "settings": {
                "foreground": "#e0def4ff"
            }
        },
        {
            "name": "comment",
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "#827f9cff"
            }
        },
        {
            "name": "comment.doc",
            "scope": [
                "comment.block.documentation"
            ],
            "settings": {
                "foreground": "#908caaff"
            }
        },
        {
            "name": "keyword",
            "scope": [
                "keyword",
                "storage.type",
                "storage.modifier",
                "keyword.control"
            ],
            "settings": {
                "foreground": "#569ab7ff"
            }
        },
        {
            "name": "string",
            "scope": [
                "string",
                "punctuation.definition.string"
            ],
            "settings": {
                "foreground": "#f6c177ff"
            }
        },
        {
            "name": "string.escape",
            "scope": [
                "constant.character.escape"
            ],
            "settings": {
                "foreground": "#ebbcbaff"
            }
        },
        {
            "name": "string.regex",
            "scope": [
                "string.regexp"
            ],
            "settings": {
                "foreground": "#f6c177ff"
            }
        },
        {
            "name": "string.special",
            "scope": [
                "string.special",
                "constant.other.placeholder"
            ],
            "settings": {
                "foreground": "#f6c177ff"
            }
        },
        {
            "name": "constant",
            "scope": [
                "constant",
                "support.constant",
                "variable.language"
            ],
            "settings": {
                "foreground": "#569ab7ff"
            }
        },
        {
            "name": "number",
            "scope": [
                "constant.numeric"
            ],
            "settings": {
                "foreground": "#ebbcbaff"
            }
        },
        {
            "name": "boolean",
            "scope": [
                "constant.language.boolean"
            ],
            "settings": {
                "foreground": "#ebbcbaff"
            }
        },
        {
            "name": "variable",
            "scope": [
                "variable",
                "meta.definition.variable"
            ],
            "settings": {
                "foreground": "#e0def4ff"
            }
        },
        {
            "name": "variable.special",
            "scope": [
                "variable.language.this",
                "variable.language.self",
                "variable.predefined"
            ],
            "settings": {
                "foreground": "#569ab7ff"
            }
        },
        {
            "name": "function",
            "scope": [
                "entity.name.function",
                "support.function",
                "meta.function-call"
            ],
            "settings": {
                "foreground": "#ebbcbaff"
            }
        },
        {
            "name": "constructor",
            "scope": [
                "entity.name.function.constructor",
                "meta.constructor"
            ],
            "settings": {
                "foreground": "#ebbcbaff"
            }
        },
        {
            "name": "type",
            "scope": [
                "entity.name.type",
                "support.type",
                "support.class",
                "storage.type"
            ],
            "settings": {
                "foreground": "#9ccfd8ff"
            }
        },
        {
            "name": "property",
            "scope": [
                "variable.other.property",
                "meta.object-literal.key",
                "support.type.property-name"
            ],
            "settings": {
                "foreground": "#e0def4ff"
            }
        },
        {
            "name": "tag",
            "scope": [
                "entity.name.tag",
                "meta.tag.sgml"
            ],
            "settings": {
                "foreground": "#9ccfd8ff"
            }
        },
        {
            "name": "attribute",
            "scope": [
                "entity.other.attribute-name"
            ],
            "settings": {
                "foreground": "#c4a7e7ff"
            }
        },
        {
            "name": "operator",
            "scope": [
                "keyword.operator"
            ],
            "settings": {
                "foreground": "#908caaff"
            }
        },
        {
            "name": "punctuation",
            "scope": [
                "punctuation"
            ],
            "settings": {
                "foreground": "#908caaff"
            }
        },
        {
            "name": "punctuation.bracket",
            "scope": [
                "meta.brace",
                "punctuation.section",
                "punctuation.separator",
                "punctuation.terminator"
            ],
            "settings": {
                "foreground": "#908caaff"
            }
        },
        {
            "name": "preproc",
            "scope": [
                "meta.preprocessor",
                "keyword.control.directive"
            ],
            "settings": {
                "foreground": "#569ab7ff"
            }
        }
    ]
}
