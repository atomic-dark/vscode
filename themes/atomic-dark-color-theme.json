    },
    "tokenColors": [
        {
            "settings": {
                "foreground": "#abb2bf"
            }
        },
        {
            "name": "comment",
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "#7f848e"
            }
        },
        {
            "name": "comment.doc",
            "scope": [
                "comment.block.documentation"
            ],
            "settings": {
                "foreground": "#8e929b"
            }
        },
        {
            "name": "keyword",
            "scope": [
                "keyword",
                "storage.type",
                "storage.modifier",
                "keyword.control"
            ],
            "settings": {
                "foreground": "#c678dd"
            }
        },
        {
            "name": "string",
            "scope": [
                "string",
                "punctuation.definition.string"
            ],
            "settings": {
                "foreground": "#98c379"
            }
        },
        {
            "name": "string.escape",
            "scope": [
                "constant.character.escape"
            ],
            "settings": {
                "foreground": "#56b6c2"
            }
        },
        {
            "name": "string.regex",
            "scope": [
                "string.regexp"
            ],
            "settings": {
                "foreground": "#98c379"
            }
        },
        {
            "name": "string.special",
            "scope": [
                "string.special",
                "constant.other.placeholder"
            ],
            "settings": {
                "foreground": "#d19a66"
            }
        },
        {
            "name": "constant",
            "scope": [
                "constant",
                "support.constant",
                "variable.language"
            ],
            "settings": {
                "foreground": "#d19a66"
            }
        },
        {
            "name": "number",
            "scope": [
                "constant.numeric"
            ],
            "settings": {
                "foreground": "#d19a66"
            }
        },
        {
            "name": "boolean",
            "scope": [
                "constant.language.boolean"
            ],
            "settings": {
                "foreground": "#d19a66"
            }
        },
        {
            "name": "variable",
            "scope": [
                "variable",
                "meta.definition.variable"
            ],
            "settings": {
                "foreground": "#abb2bf"
            }
        },
        {
            "name": "variable.special",
            "scope": [
                "variable.language.this",
                "variable.language.self",
                "variable.predefined"
            ],
            "settings": {
                "foreground": "#e06c75"
            }
        },
        {
            "name": "function",
            "scope": [
                "entity.name.function",
                "support.function",
                "meta.function-call"
            ],
            "settings": {
                "foreground": "#61afef"
            }
        },
        {
            "name": "constructor",
            "scope": [
                "entity.name.function.constructor",
                "meta.constructor"
            ],
            "settings": {
                "foreground": "#61afef"
            }
        },
        {
            "name": "type",
            "scope": [
                "entity.name.type",
                "support.type",
                "support.class",
                "storage.type"
            ],
            "settings": {
                "foreground": "#e5c07b"
            }
        },
        {
            "name": "property",
            "scope": [
                "variable.other.property",
                "meta.object-literal.key",
                "support.type.property-name"
            ],
            "settings": {
                "foreground": "#e06c75"
            }
        },
        {
            "name": "tag",
            "scope": [
                "entity.name.tag",
                "meta.tag.sgml"
            ],
            "settings": {
                "foreground": "#e06c75"
            }
        },
        {
            "name": "attribute",
            "scope": [
                "entity.other.attribute-name"
            ],
            "settings": {
                "foreground": "#61afef"
            }
        },
        {
            "name": "operator",
            "scope": [
                "keyword.operator"
            ],
            "settings": {
                "foreground": "#56b6c2"
            }
        },
        {
            "name": "punctuation",
            "scope": [
                "punctuation"
            ],
            "settings": {
                "foreground": "#abb2bf"
            }
        },
        {
            "name": "punctuation.bracket",
            "scope": [
                "meta.brace",
                "punctuation.section",
                "punctuation.separator",
                "punctuation.terminator"
            ],
            "settings": {
                "foreground": "#abb2bf"
            }
        },
        {
            "name": "preproc",
            "scope": [
                "meta.preprocessor",
                "keyword.control.directive"
            ],
            "settings": {
                "foreground": "#c678dd"
            }
        }
    ]
}