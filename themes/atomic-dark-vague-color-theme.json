        "terminal.ansiBrightBlue": "#7e98e8",
        "terminal.ansiMagenta": "#c9b1ca",
        "terminal.ansiBrightMagenta": "#aeaed1",
        "terminal.ansiCyan": "#bebeda",
        "terminal.ansiBrightCyan": "#b4d4cf",
        "terminal.ansiWhite": "#d7d7d7",
