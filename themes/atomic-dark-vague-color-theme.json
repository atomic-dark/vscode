        "titleBar.border": "#1b1e25ff",
        "activityBar.background": "#0c0e11ff",
        "activityBar.border": "#1b1e25ff",
        "statusBar.border": "#1b1e25ff",
        "editorCursor.foreground": "#cdcdcd",
        "editor.selectionBackground": "#333738",
        "activityBar.foreground": "#cdcdcd",
        "tab.activeForeground": "#cdcdcd",
        "titleBar.activeForeground": "#cdcdcd",
        "statusBar.foreground": "#cdcdcd",
        "sideBarTitle.foreground": "#cdcdcd",
        "panelTitle.activeForeground": "#cdcdcd",
        "list.activeSelectionForeground": "#cdcdcd",
        "list.hoverForeground": "#cdcdcd",
        "input.foreground": "#cdcdcd",
        "button.foreground": "#cdcdcd",
        "quickInput.foreground": "#cdcdcd",
        "menu.foreground": "#cdcdcd",
        "tab.inactiveForeground": "#606079",
        "titleBar.inactiveForeground": "#606079",
        "statusBar.debuggingForeground": "#606079",
        "activityBar.inactiveForeground": "#606079",
        "panelTitle.inactiveForeground": "#606079",
        "sideBarSectionHeader.foreground": "#606079",
        "input.background": "#111112ff",
        "input.border": "#1b1e25ff",
        "dropdown.background": "#111112ff",
        "dropdown.border": "#1b1e25ff",
        "button.background": "#405065",
        "quickInput.background": "#141415ff",
        "quickInput.border": "#1b1e25ff",
        "quickInputTitle.background": "#111112ff",
        "quickInputList.focusBackground": "#333738",
        "quickInputList.focusForeground": "#cdcdcd",
        "editorWidget.background": "#141415ff",
        "editorWidget.border": "#1b1e25ff",
        "menu.background": "#141415ff",
        "menu.border": "#1b1e25ff",
        "menu.separatorBackground": "#1b1e25ff",
        "list.inactiveSelectionBackground": "#1c1c24",
        "list.focusBackground": "#1c1c24"
    },
    "tokenColors": [
        {
            "settings": {
                "foreground": "#cdcdcd"
            }
        },
        {
            "name": "comment",
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "#606079"
            }
        },
        {
            "name": "comment.doc",
            "scope": [
                "comment.block.documentation"
            ],
            "settings": {
                "foreground": "#606079"
            }
        },
        {
            "name": "keyword",
            "scope": [
                "keyword",
                "storage.type",
                "storage.modifier",
                "keyword.control"
            ],
            "settings": {
                "foreground": "#6e94b2"
            }
        },
        {
            "name": "string",
            "scope": [
                "string",
                "punctuation.definition.string"
            ],
            "settings": {
                "foreground": "#e8b589"
            }
        },
        {
            "name": "string.escape",
            "scope": [
                "constant.character.escape"
            ],
            "settings": {
                "foreground": "#e8b589"
            }
        },
        {
            "name": "string.regex",
            "scope": [
                "string.regexp"
            ],
            "settings": {
                "foreground": "#e8b589"
            }
        },
        {
            "name": "string.special",
            "scope": [
                "string.special",
                "constant.other.placeholder"
            ],
            "settings": {
                "foreground": "#e8b589"
            }
        },
        {
            "name": "constant",
            "scope": [
                "constant",
                "support.constant",
                "variable.language"
            ],
            "settings": {
                "foreground": "#aeaed1"
            }
        },
        {
            "name": "number",
            "scope": [
                "constant.numeric"
            ],
            "settings": {
                "foreground": "#e0a363"
            }
        },
        {
            "name": "boolean",
            "scope": [
                "constant.language.boolean"
            ],
            "settings": {
                "foreground": "#e0a363"
            }
        },
        {
            "name": "variable",
            "scope": [
                "variable",
                "meta.definition.variable"
            ],
            "settings": {
                "foreground": "#cdcdcd"
            }
        },
        {
            "name": "variable.special",
            "scope": [
                "variable.language.this",
                "variable.language.self",
                "variable.predefined"
            ],
            "settings": {
                "foreground": "#bb9dbd"
            }
        },
        {
            "name": "function",
            "scope": [
                "entity.name.function",
                "support.function",
                "meta.function-call"
            ],
            "settings": {
                "foreground": "#c48282"
            }
        },
        {
            "name": "constructor",
            "scope": [
                "entity.name.function.constructor",
                "meta.constructor"
            ],
            "settings": {
                "foreground": "#c48282"
            }
        },
        {
            "name": "type",
            "scope": [
                "entity.name.type",
                "support.type",
                "support.class",
                "storage.type"
            ],
            "settings": {
                "foreground": "#9bb4bc"
            }
        },
        {
            "name": "property",
            "scope": [
                "variable.other.property",
                "meta.object-literal.key",
                "support.type.property-name"
            ],
            "settings": {
                "foreground": "#c3c3d5"
            }
        },
        {
            "name": "tag",
            "scope": [
                "entity.name.tag",
                "meta.tag.sgml"
            ],
            "settings": {
                "foreground": "#6e94b2"
            }
        },
        {
            "name": "attribute",
            "scope": [
                "entity.other.attribute-name"
            ],
            "settings": {
                "foreground": "#c3c3d5"
            }
        },
        {
            "name": "operator",
            "scope": [
                "keyword.operator"
            ],
            "settings": {
                "foreground": "#90a0b5"
            }
        },
        {
            "name": "punctuation",
            "scope": [
                "punctuation"
            ],
            "settings": {
                "foreground": "#cdcdcd"
            }
        },
        {
            "name": "punctuation.bracket",
            "scope": [
                "meta.brace",
                "punctuation.section",
                "punctuation.separator",
                "punctuation.terminator"
            ],
            "settings": {
                "foreground": "#cdcdcd"
            }
        },
        {
            "name": "preproc",
            "scope": [
                "meta.preprocessor",
                "keyword.control.directive"
            ],
            "settings": {
                "foreground": "#b4d4cf"
            }
        }
    ]
}
