        "quickInput.background": "#0e1518ff",
        "quickInput.border": "#1b1e25ff",
        "quickInputTitle.background": "#0a1114ff",
        "quickInputList.focusBackground": "#3b414eff",
        "quickInputList.focusForeground": "#eeffffff",
        "editorWidget.background": "#0e1518ff",
        "editorWidget.border": "#1b1e25ff",
        "menu.background": "#0e1518ff",
        "menu.border": "#1b1e25ff",
        "menu.separatorBackground": "#1b1e25ff",
        "list.inactiveSelectionBackground": "#232933ff",
        "list.focusBackground": "#232933ff",
        "window.activeBorder": "#1b1e25ff",
        "window.inactiveBorder": "#1b1e25ff"
    },
    "tokenColors": [
        {
            "settings": {
                "foreground": "#cdd3deff"
            }
        },
        {
            "name": "comment",
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "#7492a0ff"
            }
        },
        {
            "name": "comment.doc",
            "scope": [
                "comment.block.documentation"
            ],
            "settings": {
                "foreground": "#8ca4b0ff"
            }
        },
        {
            "name": "keyword",
            "scope": [
                "keyword",
                "storage.type",
                "storage.modifier",
                "keyword.control"
            ],
            "settings": {
                "foreground": "#c792eaff"
            }
        },
        {
            "name": "string",
            "scope": [
                "string",
                "punctuation.definition.string"
            ],
            "settings": {
                "foreground": "#c3e88dff"
            }
        },
        {
            "name": "string.escape",
            "scope": [
                "constant.character.escape"
            ],
            "settings": {
                "foreground": "#8ca4b0ff"
            }
        },
        {
            "name": "string.regex",
            "scope": [
                "string.regexp"
            ],
            "settings": {
                "foreground": "#f78c6cff"
            }
        },
        {
            "name": "string.special",
            "scope": [
                "string.special",
                "constant.other.placeholder"
            ],
            "settings": {
                "foreground": "#f78c6cff"
            }
        },
        {
            "name": "constant",
            "scope": [
                "constant",
                "support.constant",
                "variable.language"
            ],
            "settings": {
                "foreground": "#ffcb6bff"
            }
        },
        {
            "name": "number",
            "scope": [
                "constant.numeric"
            ],
            "settings": {
                "foreground": "#f78c6cff"
            }
        },
        {
            "name": "boolean",
            "scope": [
                "constant.language.boolean"
            ],
            "settings": {
                "foreground": "#f78c6cff"
            }
        },
        {
            "name": "variable",
            "scope": [
                "variable",
                "meta.definition.variable"
            ],
            "settings": {
                "foreground": "#eeffffff"
            }
        },
        {
            "name": "variable.special",
            "scope": [
                "variable.language.this",
                "variable.language.self",
                "variable.predefined"
            ],
            "settings": {
                "foreground": "#f78c6cff"
            }
        },
        {
            "name": "function",
            "scope": [
                "entity.name.function",
                "support.function",
                "meta.function-call"
            ],
            "settings": {
                "foreground": "#82aaffff"
            }
        },
        {
            "name": "constructor",
            "scope": [
                "entity.name.function.constructor",
                "meta.constructor"
            ],
            "settings": {
                "foreground": "#82aaffff"
            }
        },
        {
            "name": "type",
            "scope": [
                "entity.name.type",
                "support.type",
                "support.class",
                "storage.type"
            ],
            "settings": {
                "foreground": "#89ddffff"
            }
        },
        {
            "name": "property",
            "scope": [
                "variable.other.property",
                "meta.object-literal.key",
                "support.type.property-name"
            ],
            "settings": {
                "foreground": "#ff5370ff"
            }
        },
        {
            "name": "tag",
            "scope": [
                "entity.name.tag",
                "meta.tag.sgml"
            ],
            "settings": {
                "foreground": "#82aaffff"
            }
        },
        {
            "name": "attribute",
            "scope": [
                "entity.other.attribute-name"
            ],
            "settings": {
                "foreground": "#ffcb6bff"
            }
        },
        {
            "name": "operator",
            "scope": [
                "keyword.operator"
            ],
            "settings": {
                "foreground": "#89ddffff"
            }
        },
        {
            "name": "punctuation",
            "scope": [
                "punctuation"
            ],
            "settings": {
                "foreground": "#cdd3deff"
            }
        },
        {
            "name": "punctuation.bracket",
            "scope": [
                "meta.brace",
                "punctuation.section",
                "punctuation.separator",
                "punctuation.terminator"
            ],
            "settings": {
                "foreground": "#b0bfd0ff"
            }
        },
        {
            "name": "preproc",
            "scope": [
                "meta.preprocessor",
                "keyword.control.directive"
            ],
            "settings": {
                "foreground": "#eeffffff"
            }
        }
    ]
}