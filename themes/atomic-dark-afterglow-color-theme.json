    },
    "tokenColors": [
        {
            "settings": {
                "foreground": "#d6d6d6ff"
            }
        },
        {
            "name": "comment",
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "#898989ff"
            }
        },
        {
            "name": "comment.doc",
            "scope": [
                "comment.block.documentation"
            ],
            "settings": {
                "foreground": "#999999ff"
            }
        },
        {
            "name": "keyword",
            "scope": [
                "keyword",
                "storage.type",
                "storage.modifier",
                "keyword.control"
            ],
            "settings": {
                "foreground": "#e5a05eff"
            }
        },
        {
            "name": "string",
            "scope": [
                "string",
                "punctuation.definition.string"
            ],
            "settings": {
                "foreground": "#b4c973ff"
            }
        },
        {
            "name": "string.escape",
            "scope": [
                "constant.character.escape"
            ],
            "settings": {
                "foreground": "#d67fa3ff"
            }
        },
        {
            "name": "string.regex",
            "scope": [
                "string.regexp"
            ],
            "settings": {
                "foreground": "#b4c973ff"
            }
        },
        {
            "name": "string.special",
            "scope": [
                "string.special",
                "constant.other.placeholder"
            ],
            "settings": {
                "foreground": "#b4c973ff"
            }
        },
        {
            "name": "constant",
            "scope": [
                "constant",
                "support.constant",
                "variable.language"
            ],
            "settings": {
                "foreground": "#6d9cbeff"
            }
        },
        {
            "name": "number",
            "scope": [
                "constant.numeric"
            ],
            "settings": {
                "foreground": "#b4c973ff"
            }
        },
        {
            "name": "boolean",
            "scope": [
                "constant.language.boolean"
            ],
            "settings": {
                "foreground": "#e5a05eff"
            }
        },
        {
            "name": "variable",
            "scope": [
                "variable",
                "meta.definition.variable"
            ],
            "settings": {
                "foreground": "#d0d0ffff"
            }
        },
        {
            "name": "variable.special",
            "scope": [
                "variable.language.this",
                "variable.language.self",
                "variable.predefined"
            ],
            "settings": {
                "foreground": "#e5a05eff"
            }
        },
        {
            "name": "function",
            "scope": [
                "entity.name.function",
                "support.function",
                "meta.function-call"
            ],
            "settings": {
                "foreground": "#ffc66dff"
            }
        },
        {
            "name": "constructor",
            "scope": [
                "entity.name.function.constructor",
                "meta.constructor"
            ],
            "settings": {
                "foreground": "#6c99bbff"
            }
        },
        {
            "name": "type",
            "scope": [
                "entity.name.type",
                "support.type",
                "support.class",
                "storage.type"
            ],
            "settings": {
                "foreground": "#6c99bbff"
            }
        },
        {
            "name": "property",
            "scope": [
                "variable.other.property",
                "meta.object-literal.key",
                "support.type.property-name"
            ],
            "settings": {
                "foreground": "#ee9a82ff"
            }
        },
        {
            "name": "tag",
            "scope": [
                "entity.name.tag",
                "meta.tag.sgml"
            ],
            "settings": {
                "foreground": "#e8bf6aff"
            }
        },
        {
            "name": "attribute",
            "scope": [
                "entity.other.attribute-name"
            ],
            "settings": {
                "foreground": "#e5a05eff"
            }
        },
        {
            "name": "operator",
            "scope": [
                "keyword.operator"
            ],
            "settings": {
                "foreground": "#e5a05eff"
            }
        },
        {
            "name": "punctuation",
            "scope": [
                "punctuation"
            ],
            "settings": {
                "foreground": "#b0b0b0ff"
            }
        },
        {
            "name": "punctuation.bracket",
            "scope": [
                "meta.brace",
                "punctuation.section",
                "punctuation.separator",
                "punctuation.terminator"
            ],
            "settings": {
                "foreground": "#a0a0a0ff"
            }
        },
        {
            "name": "preproc",
            "scope": [
                "meta.preprocessor",
                "keyword.control.import",
                "keyword.control.directive"
            ],
            "settings": {
                "foreground": "#d6d6d6ff"
            }
        }
    ]
}